# =====================================================
# Ephemeral Chat - Environment Variables
# Copy this to .env and fill in your values
# NEVER commit .env to version control
# =====================================================

# Server
PORT=3001
NODE_ENV=development

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5500

# MySQL Database
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_mysql_password
DB_NAME=ephemeral_chat

# JWT Secret (generate a strong random string)
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production_min_32_chars

# Admin JWT expiry
JWT_EXPIRES_IN=8h

# File Upload
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=25
ALLOWED_TYPES=image/jpeg,image/png,image/gif,image/webp,application/pdf,text/plain,application/zip,application/x-zip-compressed,video/mp4,audio/mpeg,audio/wav

# Room Settings
ROOM_EXPIRY_HOURS=24
ROOM_INACTIVITY_MINUTES=60
MAX_ROOM_PARTICIPANTS=50

# Chat Logs (set to 'true' to retain chat logs for moderation - disclose to users)
RETAIN_CHAT_LOGS=false

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# Render/Production (set automatically by Render)
# RENDER=true
